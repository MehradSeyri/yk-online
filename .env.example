# Common
NODE_ENV=production
SELF_URL=https://yk-online.eu
SHOP_DOMAIN=https://aaa.cz
INTERNAL_API_SECRET=

# Forward na AAA.CZ Supabase Edge Function
SHOP_WEBHOOK_URL=https://<SUPABASE_PROJECT_REF>.supabase.co/functions/v1/payment-webhook
SHOP_SUPABASE_ANON_KEY=

# Router provideru
PAYMENT_PROVIDER_PRIMARY=comgate
PAYMENT_PROVIDER_FALLBACK=viva

# Comgate
COMGATE_ENV=live
COMGATE_MERCHANT=
COMGATE_SECRET=
COMGATE_METHOD=ALL

# GlobalPayments
GP_ENV=live
GP_APP_ID=
GP_APP_KEY=
GP_ACCOUNT_NAME=
GP_API_VERSION=2021-03-22
GP_WEBHOOK_TOKEN=

# Viva
VIVA_ENV=live
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=
VIVA_SOURCE_CODE=
VIVA_WEBHOOK_KEY=

# Database (Supabase + Prisma)
# IMPORTANT: the direct host db.<ref>.supabase.co:5432 is IPv6-only and is
# usually UNREACHABLE from IPv4 networks / Vercel -> use the POOLER strings.
# Dashboard: Project Settings -> Database -> Connection string -> "Connection pooling".
#
# Runtime (app) — Transaction pooler, port 6543, pgbouncer=true:
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Migrations (prisma migrate) — Session pooler, port 5432, NO pgbouncer:
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Reconciliation cron protection (Bearer token expected by /api/reconcile)
CRON_SECRET=
