# Common
NODE_ENV=production
SELF_URL=https://bbb.eu
SHOP_DOMAIN=https://aaa.cz
INTERNAL_API_SECRET=

# Forward na AAA.CZ Supabase Edge Function
SHOP_WEBHOOK_URL=https://<SUPABASE_PROJECT_REF>.supabase.co/functions/v1/payment-webhook
SHOP_SUPABASE_ANON_KEY=

# Router provideru
PAYMENT_PROVIDER_PRIMARY=globalpayments
PAYMENT_PROVIDER_FALLBACK=viva

# GlobalPayments
GP_ENV=live
GP_APP_ID=
GP_APP_KEY=
GP_ACCOUNT_NAME=
GP_API_VERSION=2021-03-22
GP_WEBHOOK_TOKEN=

# Viva
VIVA_ENV=live
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=
VIVA_SOURCE_CODE=
VIVA_WEBHOOK_KEY=

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/bbb_payments?schema=public

# Reconciliation cron protection (Bearer token expected by /api/reconcile)
CRON_SECRET=
